{
  "appId": "edu.bicol.bupulse",
  "appName": "BUPulse",
  "webDir": "dist",
  "server": {
    "url": "https://bu-pulse.vercel.app",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f2010",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0f2010"
    }
  }
}
